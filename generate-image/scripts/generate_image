#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.11"
# dependencies = [
#     "requests",
#     "python-dotenv",
#     "typer",
#     "openai>=2.0.0",
# ]
# ///
"""
Generate Image Skill

Generate and edit images. Routes by model:
- gpt-image-* / openai/* -> OpenAI SDK direct (supports non-square size + quality)
- google/gemini-* -> OpenRouter chat-completions (supports aspect ratios + size tiers)
"""

from __future__ import annotations

import base64
import json
import os
from pathlib import Path
from typing import Annotated

import requests
import typer
from dotenv import load_dotenv
from openai import OpenAI

load_dotenv()

# --- Config ---

DEFAULT_MODEL = "gpt-image-2"
GEMINI_MODEL = "google/gemini-3.1-flash-image-preview"
DEFAULT_OUTPUT = "generated_image.png"

PORTRAIT_RATIOS = {"9:16", "2:3", "3:4", "4:5", "1:4", "1:8"}
LANDSCAPE_RATIOS = {"16:9", "3:2", "4:3", "5:4", "21:9", "4:1", "8:1"}

MIME_TYPES = {
    ".png": "image/png",
    ".jpg": "image/jpeg",
    ".jpeg": "image/jpeg",
    ".gif": "image/gif",
    ".webp": "image/webp",
}

ASPECT_RATIOS = [
    "1:1",
    "16:9",
    "9:16",
    "4:3",
    "3:4",
    "3:2",
    "2:3",
    "4:5",
    "5:4",
    "21:9",
    # Gemini 3.1 Flash extended ratios
    "1:4",
    "4:1",
    "1:8",
    "8:1",
]

IMAGE_SIZES = ["0.5K", "1K", "2K", "4K"]


# --- Helpers ---


def loadImageAsBase64(image_path: Path) -> str:
    """Load an image file and return it as a base64 data URL."""
    if not image_path.exists():
        typer.echo(f"Error: Image file not found: {image_path}", err=True)
        raise typer.Exit(1)

    mime_type = MIME_TYPES.get(image_path.suffix.lower(), "image/png")

    with open(image_path, "rb") as f:
        image_data = f.read()

    base64_data = base64.b64encode(image_data).decode("utf-8")
    return f"data:{mime_type};base64,{base64_data}"


def saveBase64Image(base64_data: str, output_path: Path) -> None:
    """Save base64 encoded image to file."""
    if "," in base64_data:
        base64_data = base64_data.split(",", 1)[1]

    image_data = base64.b64decode(base64_data)
    with open(output_path, "wb") as f:
        f.write(image_data)


def isOpenAI(model: str) -> bool:
    """True when the model should be called via the OpenAI SDK directly."""
    return model.startswith("openai/") or model.startswith("gpt-image")


def openAIModelId(model: str) -> str:
    """Strip any OpenRouter-style `openai/` prefix for the OpenAI SDK."""
    return model.removeprefix("openai/")


def getApiKey(model: str, api_key: str | None = None) -> str:
    """Resolve the right key for the route. OpenAI SDK -> OPENAI_API_KEY; else OPENROUTER_API_KEY."""
    if isOpenAI(model):
        key = api_key or os.getenv("OPENAI_API_KEY")
        if not key:
            typer.echo("Error: OPENAI_API_KEY not found", err=True)
            typer.echo("\nSet in .env file, export, or source ~/.secrets:", err=True)
            typer.echo("  OPENAI_API_KEY=your-api-key-here", err=True)
            typer.echo("\nGet key: https://platform.openai.com/api-keys", err=True)
            raise typer.Exit(1)
        return key

    key = api_key or os.getenv("OPENROUTER_API_KEY")
    if not key:
        typer.echo("Error: OPENROUTER_API_KEY not found", err=True)
        typer.echo("\nSet in .env file or export:", err=True)
        typer.echo("  OPENROUTER_API_KEY=your-api-key-here", err=True)
        typer.echo("\nGet key: https://openrouter.ai/keys", err=True)
        raise typer.Exit(1)
    return key


def resolveOpenAISize(size: str | None, aspect_ratio: str | None) -> str:
    """Map --size / --aspect-ratio to an OpenAI Images API size string."""
    if size:
        s = size.lower()
        if s == "auto":
            return "auto"
        if "x" in s:
            return s  # e.g. "1024x1536"
        # Gemini tier (1K/2K/4K) → ignore for OpenAI
    if aspect_ratio:
        if aspect_ratio in PORTRAIT_RATIOS:
            return "1024x1536"
        if aspect_ratio in LANDSCAPE_RATIOS:
            return "1536x1024"
    return "1024x1024"


def generateImage(
    prompt: str,
    output_path: Path,
    api_key: str,
    input_image: Path | None = None,
    aspect_ratio: str | None = None,
    max_tokens: int = 1024,
    image_size: str | None = None,
    seed: int | None = None,
    temperature: float | None = None,
    reasoning: str | None = None,
    model: str = DEFAULT_MODEL,
    quality: str | None = None,
    output_format: str | None = None,
) -> dict:
    """Dispatch to the OpenAI SDK or OpenRouter chat-completions based on model."""
    if isOpenAI(model):
        return generateImageOpenAI(
            prompt,
            output_path,
            api_key,
            input_image,
            aspect_ratio,
            image_size,
            model,
            quality,
            output_format,
        )
    return generateImageOpenRouter(
        prompt,
        output_path,
        api_key,
        input_image,
        aspect_ratio,
        max_tokens,
        image_size,
        seed,
        temperature,
        reasoning,
        model,
    )


def generateImageOpenAI(
    prompt: str,
    output_path: Path,
    api_key: str,
    input_image: Path | None,
    aspect_ratio: str | None,
    image_size: str | None,
    model: str,
    quality: str | None,
    output_format: str | None,
) -> dict:
    """Generate or edit an image via the OpenAI Images API (SDK direct)."""
    model_id = openAIModelId(model)
    size = resolveOpenAISize(image_size, aspect_ratio)
    fmt = (output_format or output_path.suffix.lstrip(".") or "png").lower()
    if fmt == "jpg":
        fmt = "jpeg"

    client = OpenAI(api_key=api_key)
    kwargs: dict = {"model": model_id, "prompt": prompt, "size": size}
    if quality:
        kwargs["quality"] = quality
    if fmt in {"png", "jpeg", "webp"}:
        kwargs["output_format"] = fmt

    if input_image is not None:
        typer.echo(f"Editing: {input_image}", err=True)
        typer.echo(f"Model: {model_id} (OpenAI SDK, size={size})", err=True)
        with open(input_image, "rb") as f:
            response = client.images.edit(image=f, **kwargs)
    else:
        typer.echo(f"Generating: {prompt[:50]}...", err=True)
        typer.echo(f"Model: {model_id} (OpenAI SDK, size={size})", err=True)
        response = client.images.generate(**kwargs)

    b64 = response.data[0].b64_json
    if not b64:
        typer.echo("Error: OpenAI response missing b64_json", err=True)
        raise typer.Exit(1)
    saveBase64Image(b64, output_path)
    typer.echo(f"Saved: {output_path}", err=True)
    return {"model": model_id, "size": size, "output": str(output_path)}


def generateImageOpenRouter(
    prompt: str,
    output_path: Path,
    api_key: str,
    input_image: Path | None = None,
    aspect_ratio: str | None = None,
    max_tokens: int = 1024,
    image_size: str | None = None,
    seed: int | None = None,
    temperature: float | None = None,
    reasoning: str | None = None,
    model: str = GEMINI_MODEL,
) -> dict:
    """Generate or edit an image via OpenRouter chat-completions (Gemini + friends)."""
    is_editing = input_image is not None

    if is_editing:
        typer.echo(f"Editing: {input_image}", err=True)
        typer.echo(f"Model: {model}", err=True)
        image_data_url = loadImageAsBase64(input_image)
        message_content = [
            {"type": "text", "text": prompt},
            {"type": "image_url", "image_url": {"url": image_data_url}},
        ]
    else:
        typer.echo(f"Generating: {prompt[:50]}...", err=True)
        typer.echo(f"Model: {model}", err=True)
        message_content = prompt

    request_body = {
        "model": model,
        "messages": [{"role": "user", "content": message_content}],
        "modalities": ["image", "text"],
        "max_tokens": max_tokens,
    }

    # image_config (aspect_ratio, image_size 0.5K/1K/2K/4K) is Gemini-specific.
    image_config = {}
    if aspect_ratio:
        image_config["aspect_ratio"] = aspect_ratio
    if image_size:
        image_config["image_size"] = image_size
    if image_config:
        request_body["image_config"] = image_config
    if seed is not None:
        request_body["seed"] = seed
    if temperature is not None:
        request_body["temperature"] = temperature
    if reasoning:
        request_body["reasoning"] = {"effort": reasoning}

    response = requests.post(
        url="https://openrouter.ai/api/v1/chat/completions",
        headers={
            "Authorization": f"Bearer {api_key}",
            "Content-Type": "application/json",
        },
        json=request_body,
    )

    if response.status_code != 200:
        typer.echo(f"API Error ({response.status_code}): {response.text}", err=True)
        raise typer.Exit(1)

    result = response.json()

    if not result.get("choices"):
        typer.echo("Error: No choices in response", err=True)
        typer.echo(f"Response: {json.dumps(result, indent=2)}", err=True)
        raise typer.Exit(1)

    message = result["choices"][0]["message"]
    images = extractImages(message)

    if not images:
        typer.echo("Error: No image in response", err=True)
        if message.get("content"):
            typer.echo(f"Content: {message['content']}", err=True)
        raise typer.Exit(1)

    image = images[0]
    image_url = image.get("image_url", {}).get("url") or image.get("url")

    if not image_url:
        typer.echo(f"Error: Unexpected image format: {image}", err=True)
        raise typer.Exit(1)

    saveBase64Image(image_url, output_path)
    typer.echo(f"Saved: {output_path}", err=True)

    return result


def extractImages(message: dict) -> list[dict]:
    """Extract images from API response message."""
    images = []

    if message.get("images"):
        images = message["images"]
    elif message.get("content"):
        content = message["content"]
        if isinstance(content, list):
            for part in content:
                if isinstance(part, dict) and part.get("type") == "image":
                    images.append(part)

    return images


# --- CLI ---


def main(
    prompt: Annotated[
        str, typer.Argument(help="Image description or editing instructions")
    ],
    output: Annotated[
        Path, typer.Option("--output", "-o", help="Output file path")
    ] = Path(DEFAULT_OUTPUT),
    input: Annotated[
        Path | None, typer.Option("--input", "-i", help="Input image for editing")
    ] = None,
    aspect_ratio: Annotated[
        str | None,
        typer.Option(
            "--aspect-ratio",
            "-a",
            help="Aspect ratio: 1:1, 16:9, 9:16, 4:3, 3:4, 3:2, 2:3, 4:5, 5:4, 21:9, 1:4, 4:1, 1:8, 8:1",
        ),
    ] = None,
    max_tokens: Annotated[
        int,
        typer.Option(
            "--max-tokens",
            "-t",
            help="Max output tokens for OpenRouter models (higher = more detail, default 1024)",
        ),
    ] = 1024,
    image_size: Annotated[
        str | None,
        typer.Option(
            "--size",
            help="Size. Gemini: 0.5K/1K/2K/4K. gpt-image-*: 1024x1024/1024x1536/1536x1024/auto",
        ),
    ] = None,
    quality: Annotated[
        str | None,
        typer.Option(
            "--quality",
            "-q",
            help="Quality tier for gpt-image-*: auto, low, medium, high",
        ),
    ] = None,
    output_format: Annotated[
        str | None,
        typer.Option(
            "--format",
            help="Output format for gpt-image-*: png (default), jpeg, webp",
        ),
    ] = None,
    seed: Annotated[
        int | None,
        typer.Option("--seed", "-s", help="Seed for reproducible generation"),
    ] = None,
    temperature: Annotated[
        float | None,
        typer.Option("--temperature", "--temp", help="Creativity (0.0-2.0)"),
    ] = None,
    reasoning: Annotated[
        str | None,
        typer.Option(
            "--reasoning",
            "-r",
            help="Reasoning effort for complex prompts (minimal, high)",
        ),
    ] = None,
    model: Annotated[
        str,
        typer.Option(
            "--model",
            "-m",
            help=f"Model id (default: {DEFAULT_MODEL}). Use google/gemini-3.1-flash-image-preview for Gemini.",
        ),
    ] = DEFAULT_MODEL,
    api_key: Annotated[
        str | None, typer.Option("--api-key", help="API key override")
    ] = None,
) -> None:
    """Generate or edit images. Routes by model to OpenAI SDK or OpenRouter."""
    key = getApiKey(model, api_key)
    generateImage(
        prompt,
        output,
        key,
        input,
        aspect_ratio,
        max_tokens,
        image_size,
        seed,
        temperature,
        reasoning,
        model,
        quality,
        output_format,
    )


if __name__ == "__main__":
    typer.run(main)
