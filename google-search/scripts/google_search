@app.command()
def autocomplete(
    query: Annotated[str, typer.Argument(help="Search query")],
    gl: Annotated[str, typer.Option("--country", "--gl", help="Country code")] = "us",
    hl: Annotated[str, typer.Option("--lang", "--hl", help="Language code")] = "en",
    fmt: Annotated[
        OutputFormat, typer.Option("--format", "-f", help="Output format")
    ] = OutputFormat.json,
) -> None:
    """Autocomplete suggestions."""
    params = {"q": query, "gl": gl, "hl": hl}
    data = executeSearch("/autocomplete", params)
    parsed = parseAutocompleteResults(data)
    if fmt == OutputFormat.table:
        for s in parsed:
            typer.echo(s)
    else:
        typer.echo(json.dumps(parsed, indent=2))


@app.command()
def reviews(
    data_id: Annotated[
        str,
        typer.Option("--data-id", "-d", help="Place data_id/cid from places search"),
    ],
    gl: Annotated[str, typer.Option("--country", "--gl", help="Country code")] = "us",
    hl: Annotated[str, typer.Option("--lang", "--hl", help="Language code")] = "en",
    fmt: Annotated[
        OutputFormat, typer.Option("--format", "-f", help="Output format")
    ] = OutputFormat.json,
) -> None:
    """Reviews for a place. Get data_id from places command cid field."""
    params = {"data_id": data_id, "gl": gl, "hl": hl}
    data = executeSearch("/reviews", params)
    parsed = parseReviewResults(data)
    output(parsed, formatReviewTable, fmt)


if __name__ == "__main__":
    app()
